{
	"compilerOptions": {
		"target": "ES2020",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": [
			"ES2020"
		],
		"strict": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "dist",
		"rootDir": ".",
		"types": [
			"node"
		]
	},
	"include": [
		"index.ts",
		"src/**/*",
		"statics/**/*",
		"**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}